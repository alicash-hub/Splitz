# Supabase — copy this file to `.env.local` and fill in your project's values.
# Find these in your Supabase project: Settings → API.
# Only VITE_-prefixed vars are exposed to the client by Vite. The anon key is
# safe to ship to the browser (it's gated by Row Level Security), but never put
# the service_role key here.
VITE_SUPABASE_URL=https://your-project-ref.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key
